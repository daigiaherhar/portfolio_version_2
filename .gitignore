# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# VS Code — uncomment to ignore local workspace settings
#.vscode/

# Flutter / Dart / Pub
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication
app.*.symbols

# Obfuscation
app.*.map.json

# Android build outputs
/android/app/debug
/android/app/profile
/android/app/release

# Android signing (do not commit secrets)
android/app/key.properties
*.jks
*.keystore

# Environment
.env
.env.*
!.env.example

# FVM
.fvm/

# Remove the next line if you want to commit the lockfile (recommended for apps)
pubspec.lock

# Generated code (re-run: dart run build_runner build --delete-conflicting-outputs)
*.g.dart
*.freezed.dart
*.config.dart
/lib/generated/

# ObjectBox (if used)
lib/objectbox-model.json

# iOS CocoaPods (many teams still commit Podfile.lock)
/ios/Pods/

# macOS
**/xcuserdata/
**/DerivedData/

# Test / mocks
*.mocks.dart

# Cursor / IDE local (optional)
#.cursor/
